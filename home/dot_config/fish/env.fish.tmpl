# fzf
set -x FZF_DEFAULT_COMMAND 'rg -g "" --hidden --ignore ".git"'
set -x FZF_DEFAULT_OPTS "--height 70% --layout=reverse --border --ansi --inline-info"

# tmux のために設定
set -g SHELL "$(which fish)"

{{- if eq .chezmoi.os "linux" }}
{{-   if (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
# WindowsのデフォルトブラウザでURL/ファイルを開く (実体は ~/bin/xdg-open)
# claude の /login や wrangler login のように xdg-open を直接呼ぶCLIにも効く
set -x BROWSER "$HOME/bin/xdg-open"
alias open="xdg-open"
{{-   end }}
{{- end }}

{{- if eq .chezmoi.os "darwin" }}
# pnpm
set -gx PNPM_HOME "$HOME/Library/pnpm"
if not string match -q -- $PNPM_HOME $PATH
  set -gx PATH "$PNPM_HOME" $PATH
end
# pnpm end
{{- end }}

# Local overrides (not git-managed)
test -f ~/.config/fish/env.local.fish && source ~/.config/fish/env.local.fish
